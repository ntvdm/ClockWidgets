<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:gravity="right|center_vertical">

    <LinearLayout
        android:id="@+id/clock_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/img_h_tens"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:adjustViewBounds="true"
            android:paddingRight="4dp" />

        <ImageView
            android:id="@+id/img_h_ones"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:adjustViewBounds="true"
            android:paddingRight="12dp" />

        <ImageView
            android:id="@+id/img_colon"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:adjustViewBounds="true" />

        <ImageView
            android:id="@+id/img_m_tens"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:adjustViewBounds="true"
            android:paddingLeft="12dp" />

        <ImageView
            android:id="@+id/img_m_ones"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:adjustViewBounds="true"
            android:paddingLeft="4dp" />
    </LinearLayout>

    <TextClock
        android:id="@+id/date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/clock_container"
        android:layout_alignRight="@id/clock_container"
        android:layout_alignEnd="@id/clock_container"
        android:layout_marginTop="8dp"
        android:format12Hour="EEEE, MMMM d"
        android:format24Hour="EEEE, MMMM d"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:typeface="sans" />

</RelativeLayout>